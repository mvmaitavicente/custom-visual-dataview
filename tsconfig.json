{
    "compilerOptions": {
        "allowJs": false,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "es2022",
        "sourceMap": true,
        "rootDir": ".",
        "outDir": "./.tmp/build/",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "5.0",
